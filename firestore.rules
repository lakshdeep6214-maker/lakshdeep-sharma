rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (required)
    //   - bio: string (optional)
    //   - gender: string (required, enum: male, female, non-binary, other)
    //   - interestedIn: list (required, strings)
    //   - birthDate: string (required, ISO 8601)
    //   - interests: list (optional, strings)
    //   - location: map (optional, {latitude, longitude})
    //   - createdAt: timestamp (required)
    //
    // Collection: swipes
    // Document ID: auto-generated
    // Fields:
    //   - fromUid: string (required)
    //   - toUid: string (required)
    //   - type: string (required, enum: like, pass)
    //   - createdAt: timestamp (required)
    //
    // Collection: matches
    // Document ID: auto-generated
    // Fields:
    //   - users: list (required, 2 strings)
    //   - createdAt: timestamp (required)
    //   - lastMessage: string (optional)
    //   - lastMessageAt: timestamp (optional)
    //
    // Collection: matches/{matchId}/messages
    // Document ID: auto-generated
    // Fields:
    //   - senderId: string (required)
    //   - text: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'photoURL', 'gender', 'interestedIn', 'birthDate', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.photoURL is string && data.photoURL.size() > 0 &&
             data.gender in ['male', 'female', 'non-binary', 'other'] &&
             data.interestedIn is list &&
             data.birthDate is string &&
             data.createdAt is timestamp;
    }

    function isValidSwipe(data) {
      return data.keys().hasAll(['fromUid', 'toUid', 'type', 'createdAt']) &&
             data.fromUid == request.auth.uid &&
             data.toUid is string &&
             data.type in ['like', 'pass'] &&
             data.createdAt is timestamp;
    }

    function isParticipant(matchData) {
      return isAuthenticated() && request.auth.uid in matchData.users;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /swipes/{swipeId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if isAuthenticated() && isValidSwipe(request.resource.data);
    }

    match /matches/{matchId} {
      allow read: if isParticipant(resource.data);
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.users;
      allow update: if isParticipant(resource.data) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt']);

      match /messages/{messageId} {
        allow read: if isParticipant(get(/databases/$(database)/documents/matches/$(matchId)).data);
        allow create: if isParticipant(get(/databases/$(database)/documents/matches/$(matchId)).data) && isValidMessage(request.resource.data);
      }
    }
  }
}
